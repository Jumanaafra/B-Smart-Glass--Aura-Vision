# ── Aura Vision Hardware Client — Configuration ───────────────────────────────
# Copy this file to .env and fill in your values.
# Both AuraClient.py and gps_client.py read from this file.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# The deviceId that links this Pi to a Guide & VI user pair in MongoDB.
# Find it in the Guide user's DB document: db.users.findOne({email:"guide@auravision.com"}).deviceId
DEVICE_ID=your-device-id-here

# Your deployed backend URL (no trailing slash)
SERVER_URL=https://your-backend.onrender.com

# ── GPS ───────────────────────────────────────────────────────────────────────

# Serial port for GPS module (default for Pi Zero 2 W hardware UART)
GPS_PORT=/dev/serial0
GPS_BAUDRATE=9600
GPS_TIMEOUT=5

# How often to emit location to the server (seconds)
GPS_EMIT_INTERVAL=3

# ── VIDEO STREAMING ───────────────────────────────────────────────────────────

# Seconds between each JPEG frame emit (~0.15 = 6-7 fps)
FRAME_INTERVAL=0.15

# Camera resolution
CAMERA_WIDTH=640
CAMERA_HEIGHT=480

# JPEG compression quality (1–100). Lower = smaller payload, lower quality.
JPEG_QUALITY=60

# ── AI VISION ─────────────────────────────────────────────────────────────────

# How often to POST a frame to /api/ai/describe (seconds). Set to 0 to disable.
AI_DESCRIBE_INTERVAL=10

# Language for AI responses: English or Tanglish
LANGUAGE=English
